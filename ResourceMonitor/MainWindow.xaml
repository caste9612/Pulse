<Window x:Class="ResourceMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:ResourceMonitor.Controls"
        Title="Pulse"
        Width="600" Height="520"
        MinWidth="380" MinHeight="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <Color x:Key="BgColor">#E81B1B23</Color>
        <Color x:Key="BorderColor">#33FFFFFF</Color>
        <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F5F5F7"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#8A8A93"/>
        <SolidColorBrush x:Key="SubtleBrush" Color="#5A5A63"/>
        <SolidColorBrush x:Key="SeparatorBrush" Color="#22FFFFFF"/>
        <SolidColorBrush x:Key="CpuBrush" Color="#6FCFE8"/>
        <SolidColorBrush x:Key="RamBrush" Color="#B987F7"/>
        <SolidColorBrush x:Key="GpuBrush" Color="#4ADE80"/>
        <SolidColorBrush x:Key="NetBrush" Color="#FBBF24"/>
        <SolidColorBrush x:Key="DiskBrush" Color="#F87171"/>
        <SolidColorBrush x:Key="TempBrush" Color="#FF8A65"/>

        <Style x:Key="HeaderButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#22FFFFFF"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="BigValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="InfoText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DimText" TargetType="TextBlock" BasedOn="{StaticResource InfoText}">
            <Setter Property="Foreground" Value="{StaticResource SubtleBrush}"/>
        </Style>
        <Style x:Key="ProcessName" TargetType="TextBlock" BasedOn="{StaticResource InfoText}">
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style x:Key="ProcessValue" TargetType="TextBlock" BasedOn="{StaticResource InfoText}">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10.5"/>
        </Style>

        <Style x:Key="ThinBar" TargetType="ProgressBar">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource DiskBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" ClipToBounds="True">
                            <Grid>
                                <Rectangle x:Name="PART_Track" Fill="Transparent"/>
                                <Grid x:Name="PART_Indicator" HorizontalAlignment="Left">
                                    <Border Background="{TemplateBinding Foreground}" Opacity="0.85" CornerRadius="3"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Cursor="Arrow">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="14" ShadowDepth="0" Opacity="0.45"/>
        </Border.Effect>

        <Grid Margin="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border x:Name="DragHandle"
                    Grid.Row="0"
                    Background="Transparent"
                    MouseLeftButtonDown="DragHandle_MouseLeftButtonDown"
                    Padding="12,6,6,4">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Path Width="16" Height="16"
                              VerticalAlignment="Center"
                              Stroke="{StaticResource CpuBrush}"
                              StrokeThickness="1.6"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Data="M 1.6,8 L 5.1,8 L 6.1,9.3 L 7,8 L 8,3.5 L 8.8,12.5 L 9.9,8 L 10.9,8 L 14.4,8"/>
                        <TextBlock Text="Pulse"
                                   Foreground="{StaticResource TextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="11.5"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0"/>
                        <TextBlock x:Name="UptimeText"
                                   Foreground="{StaticResource SubtleBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,0"/>
                        <TextBlock x:Name="PowerText"
                                   Foreground="{StaticResource TempBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,0"
                                   ToolTip="Consumo PC totale stimato (CPU + GPU + baseline ~30W)"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="PinButton" Style="{StaticResource HeaderButton}"
                                Content="&#xE718;" ToolTip="Sempre in primo piano (clicca per togglare)"
                                Click="PinButton_Click"/>
                        <Button x:Name="HideButton" Style="{StaticResource HeaderButton}"
                                Content="&#xE921;" ToolTip="Nascondi (resta in tray)"
                                Click="HideButton_Click"
                                Margin="2,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,2">
                <StackPanel Margin="12,4,12,12">

                    <!-- CPU -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Fill="{StaticResource CpuBrush}" RadiusX="2" RadiusY="2" Margin="0,2,8,2"/>
                        <StackPanel Grid.Column="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="CPU" Style="{StaticResource SectionLabel}" Foreground="{StaticResource CpuBrush}"/>
                                    <TextBlock x:Name="CpuValue" Style="{StaticResource BigValue}" Text="—"/>
                                    <TextBlock x:Name="CpuClock" Style="{StaticResource InfoText}" Margin="10,0,0,0" Text=""/>
                                    <TextBlock x:Name="CpuPower" Style="{StaticResource InfoText}" Margin="10,0,0,0" Text=""/>
                                    <TextBlock x:Name="CpuTemp" Style="{StaticResource InfoText}" Margin="10,0,0,0"
                                               Foreground="{StaticResource TempBrush}" Text=""/>
                                </StackPanel>
                                <ctrl:Sparkline x:Name="CpuSpark" Grid.Column="1" Height="26"
                                                Stroke="{StaticResource CpuBrush}" MaxValue="100" Margin="14,2,0,2"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,8"/>

                    <!-- RAM -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Fill="{StaticResource RamBrush}" RadiusX="2" RadiusY="2" Margin="0,2,8,2"/>
                        <StackPanel Grid.Column="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="RAM" Style="{StaticResource SectionLabel}" Foreground="{StaticResource RamBrush}"/>
                                    <TextBlock x:Name="RamValue" Style="{StaticResource BigValue}" Text="—"/>
                                    <TextBlock x:Name="RamUsed" Style="{StaticResource InfoText}" Margin="10,0,0,0" Text=""/>
                                </StackPanel>
                                <ctrl:Sparkline x:Name="RamSpark" Grid.Column="1" Height="26"
                                                Stroke="{StaticResource RamBrush}" MaxValue="100" Margin="14,2,0,2"/>
                            </Grid>
                            <TextBlock x:Name="RamDetail" Style="{StaticResource DimText}" Text="" Margin="0,0,0,2"/>
                        </StackPanel>
                    </Grid>

                    <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,8"/>

                    <!-- GPU -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Fill="{StaticResource GpuBrush}" RadiusX="2" RadiusY="2" Margin="0,2,8,2"/>
                        <StackPanel Grid.Column="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="GPU" Style="{StaticResource SectionLabel}" Foreground="{StaticResource GpuBrush}"/>
                                    <TextBlock x:Name="GpuValue" Style="{StaticResource BigValue}" Text="—"/>
                                    <TextBlock x:Name="GpuVram" Style="{StaticResource InfoText}" Margin="10,0,0,0" Text=""/>
                                    <TextBlock x:Name="GpuTemp" Style="{StaticResource InfoText}" Margin="10,0,0,0"
                                               Foreground="{StaticResource TempBrush}" Text=""/>
                                </StackPanel>
                                <ctrl:Sparkline x:Name="GpuSpark" Grid.Column="1" Height="26"
                                                Stroke="{StaticResource GpuBrush}" MaxValue="100" Margin="14,2,0,2"/>
                            </Grid>
                            <TextBlock x:Name="GpuDetail" Style="{StaticResource DimText}" Text="" Margin="0,0,0,2"/>
                        </StackPanel>
                    </Grid>

                    <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,8"/>

                    <!-- NET -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Fill="{StaticResource NetBrush}" RadiusX="2" RadiusY="2" Margin="0,2,8,2"/>
                        <StackPanel Grid.Column="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="NET" Style="{StaticResource SectionLabel}" Foreground="{StaticResource NetBrush}"/>
                                    <TextBlock x:Name="NetValue" Style="{StaticResource BigValue}" Text="—"/>
                                    <TextBlock x:Name="NetPing" Style="{StaticResource InfoText}" Margin="10,0,0,0" Text=""/>
                                </StackPanel>
                                <ctrl:Sparkline x:Name="NetSpark" Grid.Column="1" Height="26" AutoScale="True"
                                                Stroke="{StaticResource NetBrush}" Margin="14,2,0,2"/>
                            </Grid>
                            <TextBlock x:Name="NetDetail" Style="{StaticResource DimText}" Text="" Margin="0,0,0,2"/>
                        </StackPanel>
                    </Grid>

                    <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,8"/>

                    <!-- DISK -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Fill="{StaticResource DiskBrush}" RadiusX="2" RadiusY="2" Margin="0,2,8,2"/>
                        <StackPanel Grid.Column="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="DSK" Style="{StaticResource SectionLabel}" Foreground="{StaticResource DiskBrush}"/>
                                    <TextBlock x:Name="DiskValue" Style="{StaticResource BigValue}" Text="—"/>
                                    <TextBlock x:Name="DiskTemp" Style="{StaticResource InfoText}" Margin="10,0,0,0"
                                               Foreground="{StaticResource TempBrush}" Text=""/>
                                </StackPanel>
                                <ctrl:Sparkline x:Name="DiskSpark" Grid.Column="1" Height="26" AutoScale="True"
                                                Stroke="{StaticResource DiskBrush}" Margin="14,2,0,2"/>
                            </Grid>
                            <ItemsControl x:Name="DriveList" Margin="0,2,0,2">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource DimText}" Foreground="{StaticResource MutedBrush}"/>
                                            <ProgressBar Grid.Column="1" Style="{StaticResource ThinBar}"
                                                         Value="{Binding UsedPercent}" Maximum="100"
                                                         Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Caption}" Style="{StaticResource DimText}" FontFamily="Consolas"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>

                    <Rectangle Height="1" Fill="{StaticResource SeparatorBrush}" Margin="0,8"/>

                    <!-- TOP PROCESSES -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="TOP CPU" Style="{StaticResource SectionLabel}"
                                       Foreground="{StaticResource CpuBrush}" Margin="0,0,0,4"/>
                            <ItemsControl x:Name="TopCpuList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource ProcessName}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" Style="{StaticResource ProcessValue}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="TOP RAM" Style="{StaticResource SectionLabel}"
                                       Foreground="{StaticResource RamBrush}" Margin="0,0,0,4"/>
                            <ItemsControl x:Name="TopRamList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource ProcessName}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" Style="{StaticResource ProcessValue}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <Border x:Name="ResizeGripArea"
                    Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Width="22" Height="22"
                    Background="Transparent"
                    Cursor="SizeNWSE"
                    MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown">
                <Path Width="12" Height="12"
                      Margin="6"
                      Stroke="{StaticResource MutedBrush}"
                      StrokeThickness="1"
                      Opacity="0.6"
                      IsHitTestVisible="False"
                      Data="M 0,12 L 12,0 M 4,12 L 12,4 M 8,12 L 12,8"/>
            </Border>
        </Grid>
    </Border>
</Window>
